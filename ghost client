-- Движение платформы
local movingUp = true
task.spawn(function()
    while safePlatform and safePlatform.Parent do
        local targetY = movingUp and 50 or 10
        local distance = math.abs(targetY - safePlatform.Position.Y)
        local speed = 5
        local duration = distance / speed
        local tween = tweenService:Create(safePlatform,
            TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut),
            {Position = Vector3.new(safePlatform.Position.X, targetY, safePlatform.Position.Z)})
        tween:Play()
        tween.Completed:Wait()
        movingUp = not movingUp
    end
end)

-- Защита платформы (встроена прямо сюда, без отдельных функций)
local onPlatform = false

safePlatform.Touched:Connect(function(hit)
    if hit.Parent and hit.Parent == player.Character then
        onPlatform = true
    end
end)

safePlatform.TouchEnded:Connect(function(hit)
    if hit.Parent and hit.Parent == player.Character then
        onPlatform = false
    end
end)

-- Цикл защиты платформы + ограничение скорости
runService.Heartbeat:Connect(function()
    pcall(function()
        local char = player.Character
        if not char then
            onPlatform = false
            return
        end
        local hum = char:FindFirstChild("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp then return end

        -- Всегда ограничиваем скорость до 32
        if hum.WalkSpeed > 32 then
            hum.WalkSpeed = 32
        end

        -- Проверка расстояния до платформы
        local distToPlatform = (hrp.Position - safePlatform.Position).Magnitude
        local isAbovePlatform = hrp.Position.Y >= safePlatform.Position.Y and hrp.Position.Y <= safePlatform.Position.Y + 5

        if (onPlatform or (distToPlatform < 6 and isAbovePlatform)) then
            onPlatform = true
            hum.FallDamage = false
            hum.BreakJointsOnDeath = false

            if hum.Health < 50 then
                hum.Health = hum.MaxHealth
            end

            if distToPlatform > 8 then
                hrp.CFrame = CFrame.new(safePlatform.Position + Vector3.new(0, 3, 0))
            end
        else
            hum.FallDamage = false
            local rayDown = workspace:Raycast(hrp.Position, Vector3.new(0, -500, 0))
            if rayDown and (hrp.Position.Y - rayDown.Position.Y) > 50 then
                hrp.CFrame = CFrame.new(safePlatform.Position + Vector3.new(0, 5, 0))
            end
        end
    end)
end)

player.CharacterAdded:Connect(function(char)
    onPlatform = false
    task.wait(0.5)
    pcall(function()
        local hum = char:WaitForChild("Humanoid")
        hum.FallDamage = false
        hum.BreakJointsOnDeath = false
        if hum.WalkSpeed > 32 then
            hum.WalkSpeed = 32
        end
    end)
end)

