-- Получить позицию под ногами игрока
local function getFootPosition()
    local char = player.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    
    -- Вычисляем высоту персонажа
    local lowestY = hrp.Position.Y
    for _, part in ipairs(char:GetChildren()) do
        if part:IsA("BasePart") and part ~= hrp then
            local partBottom = part.Position.Y - (part.Size.Y / 2)
            if partBottom < lowestY then
                lowestY = partBottom
            end
        end
    end
    
    -- Позиция на 0.5 студии ниже самой низкой точки
    local footY = lowestY - 0.5
    
    Logger:Debug(string.format("Foot position: X=%.2f Y=%.2f Z=%.2f", 
        hrp.Position.X, footY, hrp.Position.Z))
    
    return Vector3.new(hrp.Position.X, footY, hrp.Position.Z)
end

-- Метод 1: Стандартный с WeldConstraint (ОСНОВНОЙ)
local function createPlatformWithWeld()
    Logger:Info("Creating platform with WeldConstraint...")
    
    local char = player.Character
    if not char then
        Logger:Error("No character")
        return false
    end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then
        Logger:Error("No HumanoidRootPart")
        return false
    end
    
    local footPos = getFootPosition()
    if not footPos then
        Logger:Error("Cannot calculate foot position")
        return false
    end
    
    -- Создаём платформу
    local plat = Instance.new("Part")
    plat.Name = "UserPlatform_" .. tostring(math.random(1000, 9999))
    plat.Size = Vector3.new(10, 1, 10)
    plat.Position = footPos
    plat.Anchored = true  -- Платформа закреплена, но игрок приварен к ней
    plat.CanCollide = true
    plat.

Transparency = 0.5
    plat.BrickColor = BrickColor.new("Medium stone grey")
    plat.Material = Enum.Material.SmoothPlastic
    plat.Parent = Workspace
    
    -- Подсветка
    local highlight = Instance.new("SelectionBox")
    highlight.Adornee = plat
    highlight.Color3 = Color3.fromRGB(100, 100, 100)
    highlight.Transparency = 0.5
    highlight.LineThickness = 0.05
    highlight.Parent = plat
    
    -- ВАЖНО: WeldConstraint между платформой и HumanoidRootPart
    -- Это заставит игрока подниматься вместе с платформой
    local weld = Instance.new("WeldConstraint")
    weld.Name = "PlatformWeld"
    weld.Part0 = plat
    weld.Part1 = hrp
    weld.Parent = plat
    
    platformObject = plat
    platformWeld = weld
    
    Logger:Info("Platform created, WeldConstraint active between platform and HumanoidRootPart")
    Logger:Info("Player will now move with the platform")
    
    return true
end

