-- ============================================
LogSystem:Info("Часть 4: Настройка защиты от удаления...")

local protectionActive = false
local protectionThread = nil

local function startProtectionSystem(gui)
    if protectionActive then return end
    protectionActive = true
    
    LogSystem:Info("Запуск системы защиты GUI...")
    
    -- Список имён для маскировки
    local disguiseNames = {
        "UI_System",
        "RobloxGUI",
        "CoreElement",
        "HUD_Overlay",
        "ChatBubble",
        "NotificationPanel",
        "LoadingScreen",
        "MainHUD",
        "PlayerOverlay",
        "SystemMessage"
    }
    
    -- Поток 1: Проверка существования GUI
    protectionThread = task.spawn(function()
        local checkCount = 0
        local lastRename = tick()
        
        while protectionActive do
            checkCount = checkCount + 1
            task.wait(0.5)
            
            pcall(function()
                -- Проверка: GUI существует?
                if not gui or not gui.Parent then

LogSystem:Error("GUI УДАЛЁН! Запускаю восстановление...")
                    protectionActive = false
                    
                    -- Пересоздаём GUI
                    createdGui = nil
                    createdParent = nil
                    usedMethod = nil
                    
                    -- Используем самый надёжный метод
                    local bestMethod = methods[1]
                    local success, newGui, newParent = pcall(function()
                        task.wait(bestMethod.delay)
                        return bestMethod.create()
                    end)
                    
                    if success and newGui then
                        LogSystem:Info("GUI восстановлен!")
                        createdGui = newGui
                        createdParent = newParent
                        usedMethod = bestMethod
                        buildFullGUI(newGui)
                        startProtectionSystem(newGui)
                    else
                        LogSystem:Error("Не удалось восстановить GUI!")
                        -- Запускаем полный цикл восстановления
                        task.spawn(function()
                            infiniteRetryLoop()
                            if createdGui then
                                buildFullGUI(createdGui)
                                startProtectionSystem(createdGui)
                            end
                        end)
                    end
                    return
                end
                
                -- Маскировка: переименование каждые 10-30 секунд
                if tick() - lastRename > (10 + math.random() * 20) then
                    local newName = disguiseNames[math.random(1, #disguiseNames)]
                    gui.Name = newName .. "_" .. tostring(math.random(1000, 9999))
                    lastRename = tick()
                    LogSystem:Debug("GUI переименован в " .. gui.Name)
                end
                
                -- Каждые 100 проверок логируем что GUI жив
                if checkCount % 100 == 0 then
                    LogSystem:Debug("GUI жив (проверка #" .. checkCount .. ")")
                end
            end)
        end
    end)
    
    -- Поток 2: Резервное копирование в другое место
    task.spawn(function()
        while protectionActive do
            task.wait(15)
            pcall(function()
                if gui and gui.Parent then
                    -- Сохраняем важные данные GUI
                    gui:SetAttribute("lastBackup", tick())
                    gui:SetAttribute("backupCount", (gui:GetAttribute("backupCount") or 0) + 1)
                end
            end)
        end
    end)
end

