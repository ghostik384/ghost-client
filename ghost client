local function Notify(msg, d)
    d = d or 3
    local f = Instance.new("Frame")
    f.Size = UDim2.new(0,280,0,40)
    f.Position = UDim2.new(1,10,0,50)
    f.BackgroundColor3 = Color3.fromRGB(20,20,25)
    f.BorderSizePixel = 0
    f.BackgroundTransparency = 0.15
    f.Parent = gui
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0,8)
    c.Parent = f
    local t = Instance.new("TextLabel")
    t.Size = UDim2.new(1,-10,1,0)
    t.Position = UDim2.new(0,5,0,0)
    t.BackgroundTransparency = 1
    t.Text = msg
    t.TextColor3 = Color3.fromRGB(255,255,255)
    t.Font = Enum.Font.Gotham
    t.TextSize = 14
    t.TextXAlignment = Enum.TextXAlignment.Left
    t.Parent = f
    f.Position = UDim2.new(1,10,0,50)
    local ts = game:GetService("TweenService")
    ts:Create(f, TweenInfo.new(0.3), {Position = UDim2.new(1,-290,0,50)}):Play()
    task.wait(d)
    ts:Create(f, TweenInfo.new(0.3), {Position = UDim2.new(1,10,0,50)}):Play()
    task.wait(0.3)
    f:Destroy()
end

