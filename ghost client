local platformActive = false
local currentPlatform = nil
local platformConnection = nil
local respawnConnection = nil

local function CreatePlatform()
    local char = player.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    if currentPlatform then
        pcall(function() currentPlatform:Destroy() end)
        currentPlatform = nil
    end
    local platform = Instance.new("Part")
    platform.Size = Vector3.new(3, 0.2, 3)
    platform.Position = hrp.Position - Vector3.new(0, 2, 0)
    platform.Anchored = true
    platform.CanCollide = true
    platform.Transparency = 0.5
    platform.BrickColor = BrickColor.new("Bright blue")
    platform.Material = Enum.Material.Neon
    platform.Parent = workspace
    local selection = Instance.new("SelectionBox")
    selection.Adornee = platform
    selection.Color3 = Color3.fromRGB(0, 150, 255)
    selection.Transparency = 0.5
    selection.LineThickness = 0.05
    selection.Parent = platform
    return platform
end

local function PlatformMoveLoop()
    if not platformActive then return end
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if not currentPlatform or not currentPlatform.Parent then
        currentPlatform = CreatePlatform()
        if not currentPlatform then return end
    end
    currentPlatform.Position = Vector3.new(hrp.Position.X, hrp.Position.Y - 2, hrp.Position.Z)
    local humanoid = char:FindFirstChild("Humanoid")
    if humanoid and humanoid.Health > 0 then
        local newPos = hrp.Position + Vector3.new(0, 40 * task.wait(), 0)
        hrp.Position = newPos
        currentPlatform.Position = Vector3.new(newPos.X, newPos.Y - 2, newPos.Z)
    end
end

local function StartPlatform()
    if platformActive then return end
    platformActive = true
    platformConnection = game:GetService("RunService").RenderStepped:Connect(PlatformMoveLoop)
    respawnConnection = player.CharacterAdded:Connect(function(newChar)
        if platformActive then
            task.wait(0.3)
            if currentPlatform then
                pcall(function() currentPlatform:Destroy() end)
                currentPlatform = nil
            end
            currentPlatform = CreatePlatform()
            Notify("🔄 Платформа восстановлена после респавна", 1.5)
        end
    end)
    Notify("🛫 Платформа активирована! Подъём 40 ст/с", 2)
end

local function StopPlatform()
    platformActive = false
    if platformConnection then
        platformConnection:Disconnect()
        platformConnection = nil
    end
    if respawnConnection then
        respawnConnection:Disconnect()
        respawnConnection = nil
    end
    if currentPlatform then
        pcall(function() currentPlatform:Destroy() end)
        currentPlatform = nil
    end
    Notify("🛬 Платформа деактивирована", 2)
end

