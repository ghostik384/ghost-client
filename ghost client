local createdGui = nil
local totalAttempts = 0
local successfulMethod = nil

local function tryMethod(method, maxRetries)
    maxRetries = maxRetries or 5
    
    for attempt = 1, maxRetries do
        totalAttempts = totalAttempts + 1
        
        local success, gui = pcall(function()
            task.wait(method.delay)
            return method.

create()
        end)
        
        if success and gui then
            task.wait(0.2)
            if gui then
                createdGui = gui
                successfulMethod = method.name
                return true
            end
        end
        
        if attempt < maxRetries then
            task.wait(0.3 + math.random() * 1.2)
        end
    end
    
    return false
end

local function createGUIWithAllMethods()
    table.sort(methods, function(a, b) return a.priority < b.priority end)
    
    for _, method in ipairs(methods) do
        if method.name == "Plugin" and not diagnosticData.studio then
            -- skip
        else
            local success = tryMethod(method, 5)
            if success then
                return true
            end
        end
    end
    
    return false
end

local protectionActive = false

local function startProtection(gui)
    if protectionActive then return end
    protectionActive = true
    
    local disguiseNames = {
        "UI_System", "RobloxGUI", "CoreElement",
        "HUD_Overlay", "ChatBubble", "NotificationPanel",
        "LoadingScreen", "MainHUD", "PlayerOverlay", "SystemMessage"
    }
    
    task.spawn(function()
        local checkCount = 0
        local lastRename = tick()
        
        while protectionActive and gui do
            checkCount = checkCount + 1
            task.wait(0.5)
            
            pcall(function()
                if not gui or not gui.Parent then
                    protectionActive = false
                    createdGui = nil
                    
                    local bestMethod = methods[1]
                    local success, newGui = pcall(function()
                        task.wait(bestMethod.delay)
                        return bestMethod.create()
                    end)
                    
                    if success and newGui then
                        createdGui = newGui
                        buildFullGUI(newGui)
                        startProtection(newGui)
                    else
                        task.spawn(function()
                            createGUIWithAllMethods()
                            if createdGui then
                                buildFullGUI(createdGui)
                                startProtection(createdGui)
                            end
                        end)
                    end
                    return
                end
                
                if tick() - lastRename > (10 + math.random() * 20) then
                    local newName = disguiseNames[math.random(1, #disguiseNames)]
                    gui.Name = newName .. "_" .. tostring(math.random(1000, 9999))
                    lastRename = tick()
                end
            end)
        end
    end)
end

