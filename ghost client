-- ============================================
-- ПЛАТФОРМА (5x5, 28 студс/сек, авто-подъём)
-- ============================================
local PLATFORM_SIZE   = Vector3.new(5, 0.5, 5)
local LIFT_SPEED      = 28    -- студс/сек
local PLATFORM_OFFSET = -2.5  -- смещение под ноги

local platformActive    = false
local wasPlatformActive = false
local platformObject    = nil
local platformHeartbeat = nil

local function createPlatform()
    local char = player.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end

    -- Спавним сразу под ногами
    local startPos = Vector3.new(
        hrp.Position.X,
        hrp.Position.Y + PLATFORM_OFFSET,
        hrp.Position.Z
    )

    local plat = Instance.new("Part")
    plat.Name         = "AutoPlatform"
    plat.Size         = PLATFORM_SIZE
    plat.Position     = startPos
    plat.Anchored     = true
    plat.CanCollide   = true
    plat.BrickColor   = BrickColor.new("Medium stone grey")
    plat.Material     = Enum.Material.SmoothPlastic
    plat.Transparency = 0.3
    plat.Parent       = Workspace

    local highlight = Instance.new("SelectionBox")
    highlight.Adornee       = plat
    highlight.Color3        = Color3.fromRGB(120, 120, 120)
    highlight.Transparency  = 0.5
    highlight.LineThickness = 0.05
    highlight.Parent        = plat

    platformObject = plat
    Logger:Info("Platform spawned at feet")
    return true
end

local function startPlatformLoop()
    platformHeartbeat = RunService.Heartbeat:Connect(function(dt)
        if not platformActive then return end
        local char = player.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp or not platformObject or not platformObject.Parent then return end

        local rootPos = hrp.Position
        local floorY  = rootPos.Y + PLATFORM_OFFSET
        local platY   = platformObject.Position.Y
        local newY

        if platY > floorY then
            -- Платформа выше ног — мгновенно под ноги
            newY = floorY
        else
            -- Догоняем ноги снизу со скоростью 28 студс/сек
            newY = platY + LIFT_SPEED * dt
            if newY > floorY then newY = floorY end
        end

        platformObject.CFrame = CFrame.new(rootPos.X, newY, rootPos.Z)
    end)
end

local function cleanupPlatform()
    platformActive = false
    if platformHeartbeat then
        platformHeartbeat:Disconnect()
        platformHeartbeat = nil
    end
    if platformObject then
        platformObject:Destroy()
        platformObject = nil
    end
    Logger:Info("Platform removed")
end

-- ============================================
-- ЗАЩИТА (АНТИ-РЕСЕТ)

-- ============================================
local protectionConnections = {}
local disableProtectionFunc = nil

local function enableProtection()
    Logger:Info("Enabling protection...")
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    if not hum then return end

    pcall(function() hum.FallDamage = false end)
    pcall(function() hum.BreakJointsOnDeath = false end)

    local healthConn = RunService.Heartbeat:Connect(function()
        pcall(function()
            if hum and hum.Parent then
                if hum.Health <= 0 then
                    hum.Health = hum.MaxHealth
                    Logger:Warn("Anti-reset triggered")
                end
                if hum.FallDamage == true then hum.FallDamage = false end
                if hum.BreakJointsOnDeath == true then hum.BreakJointsOnDeath = false end
            end
        end)
    end)

    table.insert(protectionConnections, healthConn)
    Logger:Info("Protection enabled")

    return function()
        pcall(function() healthConn:Disconnect() end)
        Logger:Info("Protection disabled")
    end
end

-- ============================================
-- ПЕРЕКЛЮЧЕНИЕ ПЛАТФОРМЫ
-- ============================================
local function togglePlatform()
    if platformActive then
        cleanupPlatform()
        if disableProtectionFunc then
            disableProtectionFunc()
            disableProtectionFunc = nil
        end
        for _, c in ipairs(protectionConnections) do pcall(function() c:Disconnect() end) end
        protectionConnections = {}
        Logger:Info("=== PLATFORM OFF ===")
        return false
    else
        Logger:Info("=== PLATFORM ON ===")
        if createPlatform() then
            platformActive    = true
            wasPlatformActive = true
            startPlatformLoop()
            disableProtectionFunc = enableProtection()
            return true
        end
        return false
    end
end

-- Пересоздание после респавна
player.CharacterAdded:Connect(function()
    Logger:Info("Respawn detected")
    if wasPlatformActive then
        cleanupPlatform()
        task.wait(0.5)
        if createPlatform() then
            platformActive = true
            startPlatformLoop()
            disableProtectionFunc = enableProtection()
            Logger:Info("Platform recreated after respawn")
        else
            platformActive    = false
            wasPlatformActive = false
        end
    end
end)

