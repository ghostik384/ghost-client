local platformActive = false
local currPlatform = nil
local platConn = nil
local respConn = nil
local bypassConn = nil

local function Bypass()
    pcall(function()
        local c = player.Character
        if c and c:FindFirstChild("HumanoidRootPart") then
            c.HumanoidRootPart:SetAttribute("LastCheckedY", -99999)
        end
    end)
end

local function MakePlatform()
    local c = player.Character
    if not c then return nil end
    local hrp = c:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    if currPlatform then pcall(function() currPlatform:Destroy() end) end
    local p = Instance.new("Part")
    p.Size = Vector3.new(3,0.2,3)
    p.Position = hrp.Position - Vector3.new(0,2,0)
    p.Anchored = true
    p.CanCollide = true
    p.Transparency = 0.4
    p.BrickColor = BrickColor.new("Bright blue")
    p.Material = Enum.Material.Neon
    p.Parent = workspace
    local sel = Instance.new("SelectionBox")
    sel.Adornee = p
    sel.Color3 = Color3.fromRGB(0,150,255)
    sel.Transparency = 0.3
    sel.Parent = p
    return p
end

local function MoveLoop()
    if not platformActive then return end
    local c = player.Character
    if not c then return end
    local hrp = c:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    Bypass()
    if not currPlatform or not currPlatform.Parent then
        currPlatform = MakePlatform()
        if not currPlatform then return end
    end
    currPlatform.Position = Vector3.new(hrp.Position.X, hrp.Position.Y - 2, hrp.Position.Z)
    local hum = c:FindFirstChild("Humanoid")
    if hum and hum.Health > 0 then
        hrp.Position = hrp.Position + Vector3.new(0, 40 * task.wait(), 0)
        currPlatform.Position = Vector3.new(hrp.Position.X, hrp.Position.Y - 2, hrp.Position.Z)
    end
end

local function StartPlat()
    if platformActive then return end
    platformActive = true
    platConn = game:GetService("RunService").RenderStepped:Connect(MoveLoop)
    bypassConn = game:GetService("RunService").Heartbeat:Connect(Bypass)
    respConn = player.CharacterAdded:Connect(function()
        if platformActive then
            task.wait(0.3)
            if currPlatform then pcall(function() currPlatform:Destroy() end) end
            currPlatform = MakePlatform()
            Notify("Платформа восстановлена",1)
        end
    end)
    Notify("Платформа + Bypass включены",2)
end

local function StopPlat()
    platformActive = false
    if platConn then platConn:Disconnect() end
    if bypassConn then bypassConn:Disconnect() end
    if respConn then respConn:Disconnect() end
    if currPlatform then pcall(function() currPlatform:Destroy() end) end
    Notify("Платформа выключена",2)
end

