        kickButton.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        kickButton.Text = "PERFECT KICK (ВКЛ)"
        statusLabel.Text = "✅ Активен"
        Notify("✅ Perfect Kick включён!", 2)
    else
        StopLoop()
        kickButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        kickButton.Text = "PERFECT KICK (ВЫКЛ)"
        statusLabel.Text = "❌ Выключен"
        Notify("❌ Perfect Kick выключен", 2)
    end
end)

