local platformMethods = {
    {name = "Standard", func = createPlatformStandard},
    {name = "Anchored", func = createPlatformAnchored},
    {name = "CFrame", func = createPlatformCFrame},
    {name = "Simple", func = createPlatformSimple},
}

local function createPlatformWithFallback()
    for i, method in ipairs(platformMethods) do
        Logger:Info("Trying method " .. i .. ": " .. method.name)
        for attempt = 1, 3 do
            local success = pcall(function()
                return method.func()
            end)
            if success and platformObject then
                Logger:Info("Platform created with method: " .. method.name)
                return true, method.name
            end
            task.wait(0.3)
        end
    end
    Logger:Error("All platform methods failed")
    return false, nil
end

local function enableProtection()
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    if not hum then return end
    
    hum.FallDamage = false
    hum.BreakJointsOnDeath = false
    hum.WalkSpeed = math.min(hum.WalkSpeed, 32)
    
    local conn1 = RunService.Heartbeat:Connect(function()
        pcall(function()
            if hum and hum.Parent then
                if hum.Health <= 0 then hum.Health = hum.MaxHealth end
                if hum.WalkSpeed > 32 then hum.WalkSpeed = 32 end
                if hum.FallDamage == true then hum.FallDamage = false end
            end
        end)
    end)
    
    protectionDisable = function()
        pcall(function() conn1:Disconnect() end)
        pcall(function()
            if hum and hum.Parent then
                hum.FallDamage = true
                hum.WalkSpeed = 16
            end
        end)
    end
end

local function disableProtection()
    if protectionDisable then
        protectionDisable()
        protectionDisable = nil
    end
end

local function cleanupPlatform()
    platformActive = false
    if animationConnection then
        pcall(function() animationConnection:Disconnect() end)
        animationConnection = nil
    end
    disableProtection()
    if platformObject then
        pcall(function() platformObject:Destroy() end)
        platformObject = nil
    end
end

local function togglePlatform()
    if platformActive then
        cleanupPlatform()
        Logger:Info("Platform disabled")
        return false
    else
        local success, methodName = createPlatformWithFallback()
        if success then
            platformActive = true
            enableProtection()
            Logger:Info("Platform enabled with method: " .. methodName)
            return true
        end
        return false
    end
end

player.CharacterAdded:Connect(function(char)
    if platformActive then
