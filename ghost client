            platBtn.Text = "ПЛАТФОРМА: ВКЛ"
            showNotification(gui, "Платформа включена")
        else
            platBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
            platBtn.Text = "ПЛАТФОРМА: ВЫКЛ"
            showNotification(gui, "Платформа выключена")
        end
    end)
    
    -- Кнопка проверки GUI
    local checkBtn = Instance.new("TextButton")
    checkBtn.Size = UDim2.new(1, 0, 0, 40)
    checkBtn.Position = UDim2.new(0, 0, 0, 150)
    checkBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 200)
    checkBtn.Text = "ПРОВЕРИТЬ GUI"
    checkBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    checkBtn.Font = Enum.Font.GothamBold
    checkBtn.TextSize = 14
    checkBtn.BorderSizePixel = 0
    checkBtn.ZIndex = 112
    checkBtn.Parent = content
    
    local checkCorner = Instance.new("UICorner")
    checkCorner.CornerRadius = UDim.new(0, 8)
    checkCorner.Parent = checkBtn
    
    checkBtn.MouseButton1Click:Connect(function()
        showNotification(gui, "✅ GUI работает! Метод: " .. (successfulMethod or "неизвестно"))
        LogSystem:Info("Самодиагностика: GUI активен")
    end)
    
    -- Кнопка пересоздания
    local recreateBtn = Instance.new("TextButton")
    recreateBtn.Size = UDim2.new(1, 0, 0, 40)
    recreateBtn.Position = UDim2.new(0, 0, 0, 200)
    recreateBtn.BackgroundColor3 = Color3.fromRGB(200, 100, 0)
    recreateBtn.Text = "ПЕРЕСОЗДАТЬ GUI"
    recreateBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    recreateBtn.Font = Enum.Font.GothamBold
    recreateBtn.TextSize = 14
    recreateBtn.BorderSizePixel = 0
    recreateBtn.ZIndex = 112
    recreateBtn.Parent = content
    
    local recreateCorner = Instance.new("UICorner")
    recreateCorner.CornerRadius = UDim.new(0, 8)
    recreateCorner.Parent = recreateBtn
    
    recreateBtn.MouseButton1Click:Connect(function()
        showNotification(gui, "Пересоздание GUI...")
        task.spawn(function()
            pcall(function() gui:Destroy() end)
            createdGui = nil
            createGUIWithAllMethods()
            if createdGui then
                buildFullGUI(createdGui)
                startProtection(createdGui)
            end
        end)
    end)
    
    -- Индикатор FPS
    local fpsLabel = Instance.new("TextLabel")
    fpsLabel.Size = UDim2.new(0, 100, 0, 20)
    fpsLabel.Position = UDim2.new(1, -110, 0, 0)
    fpsLabel.BackgroundTransparency = 1
    fpsLabel.Text = "FPS: --"
    fpsLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
    fpsLabel.Font = Enum.Font.Gotham
    fpsLabel.TextSize = 12
    fpsLabel.ZIndex = 200
    fpsLabel.Parent = gui
    
    -- Счётчик FPS
    task.spawn(function()
        local frameCount = 0
        local lastTime = tick()
        while fpsLabel and fpsLabel.Parent do
            frameCount = frameCount + 1
            if tick() - lastTime >= 1 then
                local fps = math.floor(frameCount / (tick() - lastTime))
                fpsLabel.Text = "FPS: " .. fps
                frameCount = 0
                lastTime = tick()
            end
            task.wait()
        end
    end)
    
    -- Подключение иконки
    icon.MouseButton1Click:Connect(function()
        main.Visible = not main.Visible
    end)
    
    closeBtn.MouseButton1Click:Connect(function()
        main.Visible = false
    end)
    
    -- Показываем GUI сразу
    task.wait(0.5)
    main.Visible = true
    
    LogSystem:Info("GUI построен и показан!")
    showNotification(gui, "✅ Ghost Client Ultra Fix загружен! Метод: " .. (successfulMethod or "неизвестно"))
end

