local function EnableAntiReset()
    if antiResetActive then return end
    antiResetActive = true
    
    for _, dot in ipairs(arItems) do
        dot.BackgroundColor3 = Color3.fromRGB(0,200,0)
    end
    
    antiResetConnections.humanoidCheck = runService.Heartbeat:Connect(function()
        pcall(function()
            local char = player.Character
            if not char then return end
            local hum = char:FindFirstChild("Humanoid")
            if not hum or not hum.Parent then
                local newHum = Instance.new("Humanoid")
                newHum.Parent = char
                newHum.BreakJointsOnDeath = false
                newHum.Health = 100
                Notify("Anti-Reset: Humanoid восстановлен", 1)
            end
        end)
    end)
    
    antiResetConnections.breakJointsBlock = player.CharacterAdded:Connect(function(char)
        pcall(function()
            local hum = char:WaitForChild("Humanoid", 5)
            if hum then
                hum.BreakJointsOnDeath = false
                antiResetConnections.breakJointsProtect = hum:GetPropertyChangedSignal("BreakJointsOnDeath"):Connect(function()
                    hum.BreakJointsOnDeath = false
                end)
            end
        end)
    end)
    
    antiResetConnections.healthLock = runService.Heartbeat:Connect(function()
        pcall(function()
            local char = player.Character
            if not char then return end
            local hum = char:FindFirstChild("Humanoid")
            if hum and hum.Health < 1 then
                hum.Health = 100

Notify("Anti-Reset: Health восстановлен", 1)
            end
        end)
    end)
    
    antiResetConnections.charProtect = runService.Heartbeat:Connect(function()
        pcall(function()
            local char = player.Character
            if char and not char:IsDescendantOf(workspace) then
                char.Parent = workspace
                Notify("Anti-Reset: Персонаж возвращён", 1)
            end
        end)
    end)
    
    antiResetConnections.respawnBlock = player.CharacterAdded:Connect(function(char)
        pcall(function()
            local hum = char:WaitForChild("Humanoid", 5)
            if hum then
                hum.Died:Connect(function()
                    task.wait(0.1)
                    hum.Health = 100
                    Notify("Anti-Reset: Смерть отменена", 1)
                end)
            end
        end)
    end)
    
    antiResetConnections.partProtect = runService.Heartbeat:Connect(function()
        pcall(function()
            local char = player.Character
            if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local head = char:FindFirstChild("Head")
            if hrp and not hrp:IsDescendantOf(char) then hrp.Parent = char end
            if head and not head:IsDescendantOf(char) then head.Parent = char end
        end)
    end)
    
    Notify("Anti-Reset активирован (6 защит)", 2)
end

local function DisableAntiReset()
    antiResetActive = false
    for _, conn in pairs(antiResetConnections) do
        pcall(function() conn:Disconnect() end)
    end
    antiResetConnections = {}
    
    for _, dot in ipairs(arItems) do
        dot.BackgroundColor3 = Color3.fromRGB(200,50,50)
    end
    
    Notify("Anti-Reset выключен", 2)
end

