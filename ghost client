-- // ПОИСК ЗЕЛЁНОЙ КНОПКИ KICK! // --
local function FindKickButton()
    -- Ищем кнопку KICK на экране (в ScreenGui или PlayerGui)
    for _, guiObj in pairs(player.PlayerGui:GetDescendants()) do
        if guiObj:IsA("TextButton") or guiObj:IsA("ImageButton") then
            local text = guiObj.Text or ""
            if text:upper():find("KICK") then
                -- Проверяем что кнопка зелёная
                local color = guiObj.BackgroundColor3
                if color.R < 0.3 and color.G > 0.5 and color.B < 0.4 then
                    return guiObj
                end
            end
        end
    end
    
    -- Альтернативный поиск по имени
    for _, guiObj in pairs(player.PlayerGui:GetDescendants()) do
        if guiObj:IsA("TextButton") and guiObj.Name:lower():find("kick") then
            return guiObj
        end
    end
    return nil
end

