local PlatformDiagnostic = {}

function PlatformDiagnostic:CheckCharacter()
    if not LocalPlayer then
        Logger:Error("No LocalPlayer", "PlatformDiagnostic")
        return false, "No LocalPlayer"
    end
    
    local character = LocalPlayer.Character
    if not character then

Logger:Warn("No character", "PlatformDiagnostic")
        return false, "No character"
    end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then
        Logger:Warn("No Humanoid", "PlatformDiagnostic")
        return false, "No Humanoid"
    end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then
        Logger:Warn("No HumanoidRootPart", "PlatformDiagnostic")
        return false, "No HumanoidRootPart"
    end
    
    Logger:Debug("Character check passed", "PlatformDiagnostic")
    return true, {
        character = character,
        humanoid = humanoid,
        hrp = hrp
    }
end

function PlatformDiagnostic:GetFootPosition()
    local success, data = self:CheckCharacter()
    if not success then
        return nil, data
    end
    
    local hrp = data.hrp
    local character = data.character
    
    local totalHeight = 0
    for _, part in ipairs(character:GetChildren()) do
        if part:IsA("BasePart") then
            local partBottom = part.Position.Y - (part.Size.Y / 2)
            if partBottom < hrp.Position.Y then
                totalHeight = math.max(totalHeight, hrp.Position.Y - partBottom)
            end
        end
    end
    
    if totalHeight == 0 then
        totalHeight = 3
    end
    
    local footY = hrp.Position.Y - totalHeight - 0.5
    
    Logger:Debug(string.format(
        "Foot position calculated: (%.2f, %.2f, %.2f)",
        hrp.Position.X,
        footY,
        hrp.Position.Z
    ), "PlatformDiagnostic")
    
    return Vector3.new(hrp.Position.X, footY, hrp.Position.Z), nil
end

function PlatformDiagnostic:RaycastDown(origin, distance)
    distance = distance or 10
    
    if not Workspace then
        Logger:Error("No Workspace", "PlatformDiagnostic")
        return nil
    end
    
    local rayOrigin = origin
    local rayDirection = Vector3.new(0, -distance, 0)
    
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    if LocalPlayer and LocalPlayer.Character then
        rayParams.FilterDescendantsInstances = {LocalPlayer.Character}
    end
    
    local rayResult = Workspace:Raycast(rayOrigin, rayDirection, rayParams)
    
    if rayResult then
        Logger:Debug(string.format(
            "Raycast hit at Y=%.2f, material=%s",
            rayResult.Position.Y,
            tostring(rayResult.Material)
        ), "PlatformDiagnostic")
        return rayResult.Position, rayResult.Instance
    else
        Logger:Debug("Raycast missed", "PlatformDiagnostic")
        return nil, nil
    end
end

function PlatformDiagnostic:FindExistingPlatforms()
    if not Workspace then return {} end
    
    local existing = {}
    for _, obj in ipairs(Workspace:GetChildren()) do
        if obj:IsA("BasePart") and obj.Name:find("UserPlatform_") then
            table.insert(existing, obj)
            Logger:Debug("Found existing platform: " .. obj.Name, "PlatformDiagnostic")
        end
    end
    
    return existing
end

function PlatformDiagnostic:ValidatePosition(position)
    if not position then
        Logger:Error("No position to validate", "PlatformDiagnostic")
        return nil
    end
    
    local correctedPosition = Vector3.new(position.X, position.Y, position.Z)
    
    if not Workspace then
        return correctedPosition
    end
    
    local region = Region3.new(
        correctedPosition - Vector3.new(5, 0.5, 5),
        correctedPosition + Vector3.new(5, 0.5, 5)
    )
    
    local partsInRegion = Workspace:FindPartsInRegion3(region, nil, 10)
    
    if #partsInRegion > 0 then
        Logger:Debug("Found " .. #partsInRegion .. " parts near platform position", "PlatformDiagnostic")
        
        for _, part in ipairs(partsInRegion) do
            if part.CanCollide and part.Transparency < 0.9 then
                local partTop = part.Position.Y + (part.Size.Y / 2)
                if partTop > correctedPosition.Y then
                    correctedPosition = Vector3.new(
                        correctedPosition.X,

partTop + 0.1,
                        correctedPosition.Z
                    )
                    Logger:Debug("Adjusted platform Y to " .. correctedPosition.Y, "PlatformDiagnostic")
                end
            end
        end
    end
    
    return correctedPosition
end

function PlatformDiagnostic:RunFullDiagnostic()
    Logger:Info("Starting full platform diagnostic", "PlatformDiagnostic")
    
    local report = {
        characterExists = false,
        hasHumanoid = false,
        hasHRP = false,
        footPosition = nil,
        groundPosition = nil,
        existingPlatforms = {},
        canPlace = false
    }
    
    local success, data = self:CheckCharacter()
    if not success then
        report.error = data
        Logger:Warn("Diagnostic failed: " .. tostring(data), "PlatformDiagnostic")
        return report
    end
    
    report.characterExists = true
    report.hasHumanoid = true
    report.hasHRP = true
    
    local footPos, err = self:GetFootPosition()
    if footPos then
        report.footPosition = footPos
        
        local groundPos, hitPart = self:RaycastDown(footPos)
        if groundPos then
            report.groundPosition = groundPos
        else
            report.groundPosition = footPos - Vector3.new(0, 3, 0)
        end
    end
    
    report.existingPlatforms = self:FindExistingPlatforms()
    report.canPlace = (report.footPosition ~= nil)
    
    Logger:Info("Diagnostic complete. Can place: " .. tostring(report.canPlace), "PlatformDiagnostic")
    
    return report
end

