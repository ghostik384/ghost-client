-- ============================================
-- ФУНКЦИИ ПЛАТФОРМЫ
-- ============================================
local function CreatePlatform()
    local char = player.Character
    if not char then return nil, nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil, nil end

    local plat = Instance.new("Part")
    plat.Name = "AntiResetPlatform"
    plat.Size = Vector3.new(10, 1, 10)
    plat.Position = Vector3.new(hrp.Position.X, hrp.Position.Y - 3, hrp.Position.Z)
    plat.Anchored = true
    plat.CanCollide = true
    plat.Transparency = 0.5
    plat.BrickColor = BrickColor.new("Medium stone grey")
    plat.Material = Enum.Material.SmoothPlastic
    plat.Parent = workspace

    local highlight = Instance.new("SelectionBox")
    highlight.Adornee = plat
    highlight.Color3 = Color3.fromRGB(100, 100, 100)
    highlight.Transparency = 0.5
    highlight.LineThickness = 0.05
    highlight.Parent = plat

    return plat, highlight
end

local function CleanupPlatform()
    platformActive = false
    if moveConnection then pcall(function() moveConnection:Disconnect() end) moveConnection = nil end
    if healthConnection then pcall(function() healthConnection:Disconnect() end) healthConnection = nil end
    if speedConnection then pcall(function() speedConnection:Disconnect() end) speedConnection = nil end
    if respawnConnection then pcall(function() respawnConnection:Disconnect() end) respawnConnection = nil end
    if highlightBox then pcall(function() highlightBox:Destroy() end) highlightBox = nil end
    if platformPart then pcall(function() platformPart:Destroy() end) platformPart = nil end

    pcall(function()
        local char = player.Character
        if char then
            local hum = char:FindFirstChild("Humanoid")
            if hum then
                hum.FallDamage = true
                hum.BreakJointsOnDeath = true
                hum.WalkSpeed = 16
            end
        end
    end)
end

local function SetupAntiReset(char)
    if not char then return end
    local hum = char:WaitForChild("Humanoid", 5)
    if not hum then return end
    hum.FallDamage = false
    hum.BreakJointsOnDeath = false
    hum.WalkSpeed = 16

    if respawnConnection then respawnConnection:Disconnect() end
    respawnConnection = hum:GetPropertyChangedSignal("BreakJointsOnDeath"):Connect(function()
        if platformActive then hum.BreakJointsOnDeath = false end
    end)
    return hum
end

local function StartPlatformMovement(plat)
    if not plat then return end
    local baseY = plat.Position.Y
    local movingUp = true
    local amplitude = 20
    local cycleTime = 3

    moveConnection = runService.RenderStepped:Connect(function(deltaTime)
        if not platformActive then return end
        if not plat or not plat.Parent then return end
        pcall(function()
            local char = player.Character
            if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            plat.Position = Vector3.new(hrp.Position.X, plat.Position.Y, hrp.Position.Z)
            local speed = (amplitude * 2) / cycleTime
            if movingUp then
                plat.Position = plat.Position + Vector3.new(0, speed * deltaTime, 0)
                if plat.Position.Y >= baseY + amplitude then
                    plat.Position = Vector3.new(plat.Position.X, baseY + amplitude, plat.Position.Z)
                    movingUp = false
                end
            else
                plat.Position = plat.Position - Vector3.new(0, speed * deltaTime, 0)
                if plat.Position.Y <= baseY then
                    plat.Position = Vector3.new(plat.Position.X, baseY, plat.Position.Z)
                    movingUp = true
                end
            end
        end)
    end)
end

local function StartHealthCheck()
    healthConnection = runService.Heartbeat:Connect(function()

if not platformActive then return end
        pcall(function()
            local char = player.Character
            if not char then return end
            local hum = char:FindFirstChild("Humanoid")
            if not hum then return end
            if hum.Health <= 0 then hum.Health = hum.MaxHealth end
            if hum.BreakJointsOnDeath == true then hum.BreakJointsOnDeath = false end
            if hum.FallDamage == true then hum.FallDamage = false end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local head = char:FindFirstChild("Head")
            if hrp and not hrp:IsDescendantOf(char) then hrp.Parent = char end
            if head and not head:IsDescendantOf(char) then head.Parent = char end
            if not char:IsDescendantOf(workspace) then char.Parent = workspace end
        end)
    end)
end

local function StartSpeedLimit()
    speedConnection = runService.RenderStepped:Connect(function()
        if not platformActive then return end
        pcall(function()
            local char = player.Character
            if not char then return end
            local hum = char:FindFirstChild("Humanoid")
            if not hum then return end
            if hum.WalkSpeed > 32 then hum.WalkSpeed = 32 end
        end)
    end)
end

local function SetupRespawnHandler()
    respawnConnection = player.CharacterAdded:Connect(function(char)
        if not platformActive then return end
        task.wait(0.5)
        SetupAntiReset(char)
        if platformPart then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                platformPart.Position = Vector3.new(hrp.Position.X, hrp.Position.Y - 3, hrp.Position.Z)
            end
        end
    end)
end

-- ============================================
-- ФУНКЦИЯ TogglePlatform
-- ============================================
local function TogglePlatform()
    if platformActive then
        CleanupPlatform()
        print("[GhostClient] Платформа выключена")
        return false
    else
        local char = player.Character
        if not char then
            warn("[GhostClient] Нет персонажа!")
            return false
        end
        local plat, highlight = CreatePlatform()
        if not plat then
            warn("[GhostClient] Не удалось создать платформу!")
            return false
        end
        platformPart = plat
        highlightBox = highlight
        platformActive = true
        SetupAntiReset(char)
        StartPlatformMovement(plat)
        StartHealthCheck()
        StartSpeedLimit()
        SetupRespawnHandler()
        print("[GhostClient] Платформа включена!")
        return true
    end
end

