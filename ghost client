-- Очистка ESP
local function ClearESP()
    if espHighlight then
        pcall(function() espHighlight:Destroy() end)
        espHighlight = nil
    end
    if espBillboard then
        pcall(function() espBillboard:Destroy() end)
        espBillboard = nil
    end
end

-- Обновление ESP
local function UpdateESP()
    if not espEnabled then
        ClearESP()
        return
    end
    
    -- Проверяем, жив ли текущий таргет
    if currentTarget then
        local stillValid = false
        pcall(function()
            if currentTarget.Parent and currentTarget.Character then
                stillValid = true
            end
        end)
        if not stillValid then
            ClearESP()
            currentTarget = nil
        end
    end
    
    -- Если нет таргета, ищем нового
    if not currentTarget then
        currentTarget = FindBestTarget()
        if currentTarget then
            CreateESPOnTarget(currentTarget)
            print("[GhostClient] ESP нацелен на: " .. currentTarget.Name)
        end
    end
end

-- Запуск/остановка ESP
local function ToggleESP()
    espEnabled = not espEnabled
    
    if espEnabled then
        -- Запускаем обновление ESP
        espUpdateConnection = runService.RenderStepped:Connect(function()
            pcall(function()
                if espEnabled and currentTarget and currentTarget.Character then
                    -- Пульсация Highlight
                    if espHighlight then
                        local pulse = math.sin(tick() * 5) * 0.2 + 0.5
                        espHighlight.FillTransparency = pulse
                    end
                    
                    -- Обновление brainrot фразы каждые 3 секунды
                    if espBillboard and math.floor(tick()) % 3 == 0 then
                        local phraseLabels = espBillboard:GetChildren()
                        if #phraseLabels >= 2 then
                            phraseLabels[2].Text = GetRandomBrainrotPhrase()
                        end
                    end
                end
            end)
        end)
        
        -- Проверка новых игроков и ухода старых
        playerCheckConnection = players.PlayerRemoving:Connect(function(plr)
            if plr == currentTarget then
                ClearESP()
                currentTarget = nil
                UpdateESP()
            end
        end)
        
        -- Начальная установка ESP
        UpdateESP()
        print("[GhostClient] ESP включен")
        return true
    else
        -- Остановка ESP
        ClearESP()
        currentTarget = nil
        if espUpdateConnection then
            pcall(function() espUpdateConnection:Disconnect() end)
            espUpdateConnection = nil
        end
        if playerCheckConnection then
            pcall(function() playerCheckConnection:Disconnect() end)
            playerCheckConnection = nil
        end
        print("[GhostClient] ESP выключен")
        return false
    end
end

