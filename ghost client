local platformMethods = {
    {name = "WeldConstraint Anchored", func = createPlatformWithWeld},
    {name = "WeldConstraint Unanchored", func = createPlatformUnanchored},
    {name = "CFrame Weld", func = createPlatformCFrame},
}

-- Создание платформы с перебором методов
local function createPlatformWithFallback()
    for i, method in ipairs(platformMethods) do
        Logger:Info("Trying platform method " .. i .. ": " .. method.name)
        for attempt = 1, 3 do
            local success = pcall(function()
                return method.func()
            end)
            if success and platformObject then
                Logger:Info("PLATFORM CREATED with method: " .. method.name)
                Logger:Info("Player WILL be lifted by the platform!")
                return true, method.name
            end
            Logger:Warn("Attempt " .. attempt .. " failed, retrying...")
            task.wait(0.3)

end
    end
    Logger:Error("ALL PLATFORM METHODS FAILED")
    return false, nil
end

-- ============================================
-- АНИМАЦИЯ ДВИЖЕНИЯ ПЛАТФОРМЫ
-- ============================================
local function startPlatformMovement()
    if not platformObject or not platformObject.Parent then
        Logger:Error("No platform to animate")
        return
    end
    
    Logger:Info("Starting platform movement animation...")
    
    local baseY = platformObject.Position.Y
    local amplitude = 20  -- Подъём на 20 студий
    local cycleTime = 3   -- Полный цикл за 3 секунды
    local startTime = tick()
    
    movementConnection = RunService.RenderStepped:Connect(function()
        if not platformActive then return end
        if not platformObject or not platformObject.Parent then return end
        
        pcall(function()
            local elapsed = tick() - startTime
            -- Синусоидальное движение
            local offset = math.sin(elapsed * (2 * math.pi / cycleTime)) * amplitude
            local newY = baseY + offset
            
            -- Обновляем позицию платформы
            if platformObject.Anchored then
                local pos = platformObject.Position
                platformObject.Position = Vector3.new(pos.X, newY, pos.Z)
            else
                -- Для не Anchored используем VectorForce или прямую установку
                platformObject.Position = Vector3.new(
                    platformObject.Position.X,
                    newY,
                    platformObject.Position.Z
                )
            end
            
            -- Отладка каждые 60 кадров
            if math.floor(elapsed * 10) % 60 == 0 then
                Logger:Debug(string.format(
                    "Platform Y: %.2f (base: %.2f, offset: %.2f)",
                    newY, baseY, offset
                ))
            end
        end)
    end)
    
    Logger:Info("Platform movement started: amplitude=" .. amplitude .. " cycle=" .. cycleTime .. "s")
end

-- ============================================
-- ЗАЩИТА (АНТИ-РЕСЕТ)
-- ============================================
local function enableProtection()
    Logger:Info("Enabling protection...")
    
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    if not hum then return end
    
    -- Сохраняем оригинальные значения
    local origFallDamage = hum.FallDamage
    local origBreakJoints = hum.BreakJointsOnDeath
    local origWalkSpeed = hum.WalkSpeed
    
    -- Применяем защиту
    hum.FallDamage = false
    hum.BreakJointsOnDeath = false
    hum.WalkSpeed = math.min(hum.WalkSpeed, 32)
    
    Logger:Info("Protection applied: FallDamage=false, BreakJoints=false, WalkSpeed<=" .. hum.WalkSpeed)
    
    -- Цикл проверки здоровья
    local healthConn = RunService.Heartbeat:Connect(function()
        pcall(function()
            if hum and hum.Parent then
                if hum.Health <= 0 then
                    hum.Health = hum.MaxHealth
                    Logger:Warn("Health reset prevented (anti-reset)")
                end
                if hum.WalkSpeed > 32 then
                    hum.WalkSpeed = 32
                end
                if hum.FallDamage == true then
                    hum.FallDamage = false
                end
                if hum.BreakJointsOnDeath == true then
                    hum.BreakJointsOnDeath = false
                end
            end
        end)
    end)
    
    table.insert(protectionConnections, healthConn)
    
    -- Возвращаем функцию отключения
    return function()
        pcall(function() healthConn:Disconnect() end)
        pcall(function()
            if hum and hum.Parent then
                hum.FallDamage = origFallDamage
                hum.BreakJointsOnDeath = origBreakJoints
                hum.WalkSpeed = origWalkSpeed
            end
        end)
        Logger:Info("Protection disabled")
    end
end

local disableProtectionFunc = nil

-- ============================================

-- ОЧИСТКА ПЛАТФОРМЫ
-- ============================================
local function cleanupPlatform()
    Logger:Info("Cleaning up platform...")
    
    platformActive = false
    
    -- Останавливаем анимацию
    if movementConnection then
        pcall(function() movementConnection:Disconnect() end)
        movementConnection = nil
        Logger:Debug("Movement animation stopped")
    end
    
    -- Отключаем защиту
    if disableProtectionFunc then
        disableProtectionFunc()
        disableProtectionFunc = nil
    end
    
    -- Очищаем соединения защиты
    for _, conn in ipairs(protectionConnections) do
        pcall(function() conn:Disconnect() end)
    end
    protectionConnections = {}
    
    -- Удаляем WeldConstraint
    if platformWeld then
        pcall(function() platformWeld:Destroy() end)
        platformWeld = nil
        Logger:Debug("WeldConstraint destroyed")
    end
    
    -- Удаляем платформу
    if platformObject then
        pcall(function() platformObject:Destroy() end)
        platformObject = nil
        Logger:Debug("Platform destroyed")
    end
    
    Logger:Info("Platform cleanup complete")
end

-- ============================================
-- ГЛАВНАЯ ФУНКЦИЯ ПЕРЕКЛЮЧЕНИЯ ПЛАТФОРМЫ
-- ============================================
local function togglePlatform()
    if platformActive then
        -- ВЫКЛЮЧЕНИЕ
        cleanupPlatform()
        Logger:Info("=== PLATFORM DISABLED ===")
        return false
    else
        -- ВКЛЮЧЕНИЕ
        Logger:Info("=== ENABLING PLATFORM ===")
        
        local success, methodName = createPlatformWithFallback()
        if not success then
            Logger:Error("Failed to create platform!")
            return false
        end
        
        platformActive = true
        wasPlatformActive = true
        
        -- Запускаем анимацию движения
        startPlatformMovement()
        
        -- Включаем защиту
        disableProtectionFunc = enableProtection()
        
        Logger:Info("=== PLATFORM ENABLED ===")
        Logger:Info("Method: " .. methodName)
        Logger:Info("Player is now WELDED to platform and will be lifted!")
        
        return true
    end
end

