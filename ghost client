-- Получение случайной brainrot-фразы
local function GetRandomBrainrotPhrase()
    return BRAINROT_PHRASES[math.random(1, #BRAINROT_PHRASES)]
end

-- Выбор лучшего игрока для ESP
local function FindBestTarget()
    local bestPlayer = nil
    local bestScore = -1
    
    -- Ищем игрока с наибольшим счётом (если есть лидерборд)

pcall(function()
        for _, plr in ipairs(players:GetPlayers()) do
            if plr ~= player and plr.Character then
                local leaderstats = plr:FindFirstChild("leaderstats")
                if leaderstats then
                    local score = leaderstats:FindFirstChild("Score") or 
                                  leaderstats:FindFirstChild("Kills") or
                                  leaderstats:FindFirstChild("Coins")
                    if score and score.Value > bestScore then
                        bestScore = score.Value
                        bestPlayer = plr
                    end
                end
            end
        end
    end)
    
    -- Если лидерборд не найден, берём случайного игрока
    if not bestPlayer then
        local otherPlayers = {}
        for _, plr in ipairs(players:GetPlayers()) do
            if plr ~= player and plr.Character then
                table.insert(otherPlayers, plr)
            end
        end
        if #otherPlayers > 0 then
            bestPlayer = otherPlayers[math.random(1, #otherPlayers)]
        end
    end
    
    return bestPlayer
end

