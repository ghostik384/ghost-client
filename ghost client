local totalAttempts = 0
local successfulMethod = nil

-- Функция попытки создания GUI одним методом
local function tryMethod(method, maxRetries)
    maxRetries = maxRetries or 5
    
    for attempt = 1, maxRetries do
        totalAttempts = totalAttempts + 1
        
        LogSystem:Debug(string.format(
            "Метод %d (%s): попытка %d/%d",
            method.priority,
            method.name,
            attempt,
            maxRetries
        ))
        
        local success, gui, parent = pcall(function()
            task.wait(method.delay)
            return method.create()
        end)
        
        if success and gui then
            -- Проверяем, что GUI действительно создался
            task.wait(0.15)
            if gui and (gui.Parent or method.priority == 15) then
                createdGui = gui

createdParent = parent
                usedMethod = method
                successfulMethod = method.name
                
                LogSystem:Info(string.format(
                    "✅ УСПЕХ! Метод %d (%s) сработал с попытки %d",
                    method.priority,
                    method.name,
                    attempt
                ))
                return true, gui, parent
            else
                LogSystem:Warning(string.format(
                    "Метод %d (%s): GUI создан но Parent исчез (античит?)",
                    method.priority,
                    method.name
                ))
                pcall(function() gui:Destroy() end)
            end
        else
            LogSystem:Debug(string.format(
                "Метод %d (%s): ошибка - %s",
                method.priority,
                method.name,
                tostring(gui or "неизвестно")
            ))
        end
        
        -- Случайная задержка перед следующей попыткой
        if attempt < maxRetries then
            local waitTime = 0.3 + math.random() * 1.2
            task.wait(waitTime)
        end
    end
    
    return false
end

-- Главная функция создания GUI (перебор всех методов)
local function createGUIWithAllMethods()
    LogSystem:Info("Начинаю перебор всех методов создания GUI...")
    
    -- Сортируем методы по приоритету
    table.sort(methods, function(a, b) return a.priority < b.priority end)
    
    for _, method in ipairs(methods) do
        -- Пропускаем методы для эксплойтов если их нет
        if method.needsExploit and diagnosticData.executor == "unknown" and not diagnosticData.studio then
            LogSystem:Debug("Пропускаю " .. method.name .. " (требуется эксплойт)")
            goto continue
        end
        
        -- Пропускаем Plugin если не в студии
        if method.name == "Plugin (Studio)" and not diagnosticData.studio then
            LogSystem:Debug("Пропускаю Plugin (не Studio)")
            goto continue
        end
        
        local success = tryMethod(method, 5)
        if success then
            return true
        end
        
        ::continue::
    end
    
    LogSystem:Error("ВСЕ 15 МЕТОДОВ НЕ СРАБОТАЛИ!")
    return false
end

-- Бесконечный цикл попыток (если все методы не сработали)
local function infiniteRetryLoop()
    local loopCount = 0
    while not createdGui do
        loopCount = loopCount + 1
        LogSystem:Warning(string.format(
            "Бесконечный цикл: попытка #%d создать GUI...",
            loopCount
        ))
        
        local success = createGUIWithAllMethods()
        if success then
            LogSystem:Info("GUI успешно создан после " .. loopCount .. " циклов!")
            return
        end
        
        LogSystem:Warning("Все методы не сработали. Повтор через 5 секунд...")
        task.wait(5)
    end
end

