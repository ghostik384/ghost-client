local Logger = {
    history = {},
    maxHistory = 150,
    levels = {
        DEBUG = 0,
        INFO = 1,
        WARN = 2,
        ERROR = 3
    },
    currentLevel = 0
}

function Logger:add(level, message, source)
    local timestamp = os.date("%H:%M:%S")
    local entry = {
        time = timestamp,
        level = level,
        message = tostring(message),
        source = source or "Unknown"
    }
    
    table.insert(self.history, entry)
    
    if #self.history > self.maxHistory then
        table.remove(self.history, 1)
    end
    
    local prefix = "[" .. timestamp .. "]"
    local levelStr = "[" .. level .. "]"
    local sourceStr = "[" .. entry.source .. "]"
    
    print(prefix .. " " .. levelStr .. " " .. sourceStr .. " " .. entry.message)
end

function Logger:Debug(msg, source) 
    if self.currentLevel <= self.levels.DEBUG then
        self:add("DEBUG", msg, source) 
    end
end

function Logger:Info(msg, source) 
    if self.currentLevel <= self.levels.INFO then
        self:add("INFO", msg, source) 
    end
end

function Logger:Warn(msg, source) 
    if self.currentLevel <= self.levels.WARN then
        self:add("WARN", msg, source) 
    end
end

function Logger:Error(msg, source) 
    if self.currentLevel <= self.levels.ERROR then
        self:add("ERROR", msg, source) 
    end
end

function Logger:GetRecent(count)
    count = count or 10
    local recent = {}
    local startIdx = math.max(1, #self.history - count + 1)
    for i = startIdx, #self.history do
        table.insert(recent, self.history[i])
    end
    return recent
end

function Logger:PrintSummary()
    print("========================================")
    print("LOG SUMMARY (Last 20 entries)")
    print("========================================")
    local recent = self:GetRecent(20)
    for _, entry in ipairs(recent) do
        print(entry.time .. " [" .. entry.level .. "] " .. entry.message)
    end
    print("========================================")
end

