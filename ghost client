local espActive     = false
local espHighlight  = nil
local espBillboard  = nil
local espUpdateConn = nil

local brainrotPhrases = {
    "SIGMA MALE 💪🗿","SKIBIDI RIZZ 🚽✨","FANUM TAX 💰😱",
    "OHIO FINAL BOSS 🏚️👹","GYATT DAYUM 🍑🔥","MEWING STREAK 🧏‍♂️📈",
    "CHUNGUS MAX 🐰💯","FLOPTOPICA KING 🏳️‍🌈👑","NO CAP FR FR 🧢💀",
    "BRAINROT DETECTED 🧠⚠️","SUSSY BAKA 😳📮","RIZZLY BEAR 🐻💋"
}

local function getRandomPhrase()
    return brainrotPhrases[math.random(1, #brainrotPhrases)]
end

local function clearESP()
    if espUpdateConn then espUpdateConn:Disconnect(); espUpdateConn = nil end
    if espHighlight  then espHighlight:Destroy();     espHighlight  = nil end
    if espBillboard  then espBillboard:Destroy();     espBillboard  = nil end
end

local function createESP(target)
    if not target or not target.Character then return end
    clearESP()
    local char = target.Character

    espHighlight = Instance.new("Highlight")
    espHighlight.Adornee          = char
    espHighlight.FillColor        = Color3.fromRGB(255, 20, 147)
    espHighlight.FillTransparency = 0.7
    espHighlight.OutlineColor     = Color3.fromRGB(255, 20, 147)
    espHighlight.Parent           = char

    espBillboard = Instance.new("BillboardGui")
    espBillboard.Size        = UDim2.new(0, 250, 0, 60)
    espBillboard.StudsOffset = Vector3.new(0, 3, 0)
    espBillboard.AlwaysOnTop = true
    espBillboard.Parent      = char

local function makeLabel(pos, text, color, size)
        local l = Instance.new("TextLabel")
        l.Size                   = UDim2.new(1, 0, 0, 20)
        l.Position               = pos
        l.BackgroundTransparency = 1
        l.Text                   = text
        l.TextColor3             = color
        l.Font                   = Enum.Font.GothamBold
        l.TextSize               = size
        l.Parent                 = espBillboard
        return l
    end

    makeLabel(UDim2.new(0,0,0,0),  target.Name,                            Color3.fromRGB(255,255,255), 14)
    local phraseLabel =
    makeLabel(UDim2.new(0,0,0,22), getRandomPhrase(),                      Color3.fromRGB(255,50,150),  12)
    makeLabel(UDim2.new(0,0,0,42), "GIVES: "..math.random(1,9999).." EXP", Color3.fromRGB(255,200,50),  12)

    espUpdateConn = RunService.Heartbeat:Connect(function()
        if tick() % 5 < 0.05 then
            pcall(function() phraseLabel.Text = getRandomPhrase() end)
        end
    end)
end

local function toggleESP()
    espActive = not espActive
    if espActive then
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= player and plr.Character then
                createESP(plr)
                Logger:Info("ESP on: " .. plr.Name)
                return true
            end
        end
        espActive = false
        Logger:Warn("No ESP target found")
        return false
    else
        clearESP()
        Logger:Info("ESP disabled")
        return false
    end
end

