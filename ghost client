-- // PERFECT KICK ДЛЯ LUCKY BLOCKS // --
local kickEnabled = false
local perfectKickConnection = nil

local function FindLuckyBlock()
    -- Ищет Lucky Block поблизости
    local character = player.Character
    if not character then return nil end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    
    local radius = 15
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (obj.Name:lower():find("lucky") or obj.Name:lower():find("block")) then
            if obj:FindFirstChild("TouchInterest") or obj:FindFirstChild("ClickDetector") then
                local dist = (hrp.Position - obj.Position).Magnitude
                if dist < radius then
                    return obj
                end
            end
        end
    end
    return nil
end

local function PerfectKick()
    local luckyBlock = FindLuckyBlock()
    if not luckyBlock then 
        return false 
    end
    
    -- Симулируем идеальный удар (тайминг)
    local humanoid = player.Character and player.Character:FindFirstChild("Humanoid")
    if humanoid then
        -- Активируем анимацию удара ногой
        local tool = player.Character:FindFirstChildWhichIsA("Tool")
        if tool then
            -- Ударяем
            game:GetService("VirtualInputManager"):SendKeyEvent(true, Enum.KeyCode.E, false, game)
            task.wait(0.05)
            game:GetService("VirtualInputManager"):SendKeyEvent(false, Enum.KeyCode.E, false, game)
        else
            -- Просто имитация клика
            for _, click in pairs(luckyBlock:GetDescendants()) do
                if click:IsA("ClickDetector") then
                    click:Click()
                end
            end
        end
        
        -- Эффект идеального попадания
        Notify("🔥 PERFECT KICK! 🔥", 1.5)
        return true
    end
    return false
end

local function StartPerfectKickLoop()
    if perfectKickConnection then 
        perfectKickConnection:Disconnect() 
    end
    
    perfectKickConnection = game:GetService("RunService").RenderStepped:Connect(function()
        if kickEnabled then
            local success = PerfectKick()
            if success then
                -- Небольшая задержка чтобы не спамило
                task.wait(0.3)
            end
        end
    end)
end

local function StopPerfectKickLoop()
    if perfectKickConnection then
        perfectKickConnection:Disconnect()
        perfectKickConnection = nil
    end
end

kickButton.MouseButton1Click:Connect(function()
    kickEnabled = not kickEnabled

if kickEnabled then
        StartPerfectKickLoop()
        kickButton.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        kickButton.Text = "PERFECT KICK: ON"
        statusLabel.Text = "Статус: Включён (авто-кик)"
        Notify("✅ Perfect Kick включён! Бей Lucky Block", 2)
    else
        StopPerfectKickLoop()
        kickButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        kickButton.Text = "PERFECT KICK (AUTO)"
        statusLabel.Text = "Статус: Выкл"
        Notify("❌ Perfect Kick выключен", 2)
    end
end)

