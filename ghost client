LogSystem:Info("========================================")
LogSystem:Info("ЗАПУСК ОСНОВНОГО ЦИКЛА")
LogSystem:Info("========================================")

local function startGUI()
    LogSystem:Info("Запуск создания GUI...")
    
    local success = createGUIWithAllMethods()
    
    if success and createdGui then

LogSystem:Info("GUI создан! Метод: " .. (successfulMethod or "неизвестно"))
        LogSystem:Info("Всего попыток: " .. totalAttempts)
        
        buildFullGUI(createdGui)
        startProtection(createdGui)
    else
        LogSystem:Error("GUI НЕ СОЗДАН! Запуск бесконечного цикла...")
        
        -- Бесконечный цикл попыток
        task.spawn(function()
            local loopCount = 0
            while not createdGui do
                loopCount = loopCount + 1
                LogSystem:Warning("Цикл #" .. loopCount .. ": попытка создать GUI...")
                
                createGUIWithAllMethods()
                
                if createdGui then
                    LogSystem:Info("GUI создан после " .. loopCount .. " циклов!")
                    buildFullGUI(createdGui)
                    startProtection(createdGui)
                    return
                end
                
                task.wait(5)
            end
        end)
    end
end

-- Автозапуск
startGUI()

