-- САМОДВИЖУЩАЯСЯ ПЛАТФОРМА + ВСТРОЕННЫЙ ANTI-RESET
-- ============================================
local safePlatform = Instance.new("Part")
safePlatform.Name = "SafeMovingPlatform"
safePlatform.Size = Vector3.new(10, 1, 10)
safePlatform.Position = Vector3.new(0, 10, 0)
safePlatform.Anchored = true
safePlatform.CanCollide = true
safePlatform.Transparency = 0.4
safePlatform.BrickColor = BrickColor.new("Cyan")
safePlatform.Material = Enum.Material.Neon
safePlatform.Parent = workspace

local platformHighlight = Instance.new("SelectionBox")
platformHighlight.Adornee = safePlatform
platformHighlight.Color3 = Color3.fromRGB(0, 255, 255)
platformHighlight.Transparency = 0.4
platformHighlight.Parent = safePlatform

-- Движение платформы
local movingUp = true
task.spawn(function()
    while safePlatform and safePlatform.Parent do
        local targetY = movingUp and 50 or 10
        local distance = math.abs(targetY - safePlatform.Position.Y)
        local duration = distance / 5
        local tween = tweenService:Create(safePlatform,
            TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut),
            {Position = Vector3.new(safePlatform.Position.X, targetY, safePlatform.Position.Z)})
        tween:Play()
        tween.Completed:Wait()
        movingUp = not movingUp
    end
end)

-- ВСТРОЕННЫЙ ANTI-RESET (внутри кода платформы)
local onPlatform = false

safePlatform.Touched:Connect(function(hit)
    if hit.Parent and hit.Parent == player.Character then
        onPlatform = true
    end
end)

safePlatform.TouchEnded:Connect(function(hit)
    if hit.Parent and hit.Parent == player.Character then
        onPlatform = false
    end
end)

-- Главный цикл: платформа + anti-reset + ограничение скорости
runService.Heartbeat:Connect(function()
    pcall(function()
        local char = player.Character
        if not char then
            onPlatform = false
            return
        end
        
        local hum = char:FindFirstChild("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp then return end
        
        -- Ограничение скорости всегда
        if hum.WalkSpeed > 32 then
            hum.WalkSpeed = 32
        end
        
        -- Проверка на платформе
        local distToPlatform = (hrp.Position - safePlatform.Position).Magnitude
        local isAbovePlatform = hrp.Position.Y >= safePlatform.Position.Y 
                                and hrp.Position.Y <= safePlatform.Position.Y + 5
        
        if onPlatform or (distToPlatform < 6 and isAbovePlatform) then
            onPlatform = true
            
            -- ANTI-RESET ЗАЩИТА ВНУТРИ ПЛАТФОРМЫ:
            hum.FallDamage = false                    -- Нет урона от падения
            hum.BreakJointsOnDeath = false            -- Нет смерти через BreakJoints
            
            if hum.Health < 100 then                  -- Здоровье всегда полное
                hum.Health = hum.MaxHealth
            end
            
            if distToPlatform > 8 then                -- Телепорт обратно если унесло
                hrp.CFrame = CFrame.new(safePlatform.Position + Vector3.new(0, 3, 0))
            end
            
            -- Блокировка респавна через LoadCharacter
            if player.LoadCharacter then
                local oldLoad = player.LoadCharacter
                player.LoadCharacter = function()
                    return nil -- Блокируем респавн пока на платформе
                end
            end
            
            -- Защита частей тела от удаления
            for _, part in ipairs(char:GetChildren()) do
                if part:IsA("BasePart") and not part:IsDescendantOf(char) then
                    part.Parent = char
                end
            end
            
        else

-- Не на платформе: только защита от падения
            hum.FallDamage = false
            
            local rayDown = workspace:Raycast(hrp.Position, Vector3.new(0, -500, 0))
            if rayDown and (hrp.Position.Y - rayDown.Position.Y) > 50 then
                hrp.CFrame = CFrame.new(safePlatform.Position + Vector3.new(0, 5, 0))
            end
        end
    end)
end)

-- Переподключение защиты после респавна
player.CharacterAdded:Connect(function(char)
    onPlatform = false
    task.wait(0.5)
    pcall(function()
        local hum = char:WaitForChild("Humanoid")
        hum.FallDamage = false
        hum.BreakJointsOnDeath = false
        if hum.WalkSpeed > 32 then
            hum.WalkSpeed = 32
        end
        
        -- Восстановление Humanoid если удалили
        char.ChildRemoved:Connect(function(child)
            if child:IsA("Humanoid") then
                task.wait(0.1)
                local newHum = Instance.new("Humanoid")
                newHum.Parent = char
                newHum.BreakJointsOnDeath = false
                newHum.Health = 100
            end
        end)
    end)
end)

