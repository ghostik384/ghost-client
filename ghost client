-- ПЛАТФОРМА (5x5, 45 студс/сек)
-- ============================================
local PLATFORM_SIZE   = Vector3.new(5, 0.5, 5)
local LIFT_SPEED      = 45
local PLATFORM_OFFSET = -2.5

local platformActive    = false
local wasPlatformActive = false
local platformObject    = nil
local platformHeartbeat = nil

local function createPlatform()
    local char = player.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end

    local startPos = Vector3.new(hrp.Position.X, hrp.Position.Y + PLATFORM_OFFSET, hrp.Position.Z)

    local plat = Instance.new("Part")
    plat.Name         = "AutoPlatform"
    plat.Size         = PLATFORM_SIZE
    plat.Position     = startPos
    plat.Anchored     = true
    plat.CanCollide   = true
    plat.BrickColor   = BrickColor.new("Medium stone grey")
    plat.Material     = Enum.Material.SmoothPlastic
    plat.Transparency = 0.3
    plat.Parent       = Workspace

    local highlight = Instance.new("SelectionBox")
    highlight.Adornee       = plat
    highlight.Color3        = Color3.fromRGB(120,120,120)
    highlight.Transparency  = 0.5
    highlight.LineThickness = 0.05
    highlight.Parent        = plat

    platformObject = plat
    Logger:Info("Platform spawned at feet")
    return true
end

local function startPlatformLoop()
    platformHeartbeat = RunService.Heartbeat:Connect(function(dt)
        if not platformActive then return end
        local char = player.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp or not platformObject or not platformObject.Parent then return end

        local rootPos = hrp.Position
        local floorY  = rootPos.Y + PLATFORM_OFFSET
        local platY   = platformObject.Position.Y
        local newY

        if platY > floorY then
            newY = floorY
        else
            newY = platY + LIFT_SPEED * dt
            if newY > floorY then newY = floorY end
        end

        platformObject.CFrame = CFrame.new(rootPos.X, newY, rootPos.Z)
    end)
end

local function cleanupPlatform()
    platformActive = false
    if platformHeartbeat then platformHeartbeat:Disconnect(); platformHeartbeat = nil end
    if platformObject    then platformObject:Destroy();       platformObject    = nil end
    Logger:Info("Platform removed")
end

