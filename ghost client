    subtitle.Parent = bg
    
    tweenService:Create(subtitle, TweenInfo.new(0.8, Enum.EasingStyle.Back), 
        {TextTransparency = 0}):Play()
    
    -- Полоска загрузки (фон)
    local barBg = Instance.new("Frame")
    barBg.Name = "LoadingBarBg"
    barBg.Size = UDim2.new(0, 320, 0, 24)
    barBg.Position = UDim2.new(0.5, -160, 0.5, -12)
    barBg.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    barBg.BorderSizePixel = 0
    barBg.ZIndex = 201
    barBg.BackgroundTransparency = 1
    barBg.Parent = bg
    
    local barBgCorner = Instance.new("UICorner")
    barBgCorner.CornerRadius = UDim.new(0, 12)
    barBgCorner.Parent = barBg
    
    tweenService:Create(barBg, TweenInfo.new(0.5), {BackgroundTransparency = 0}):Play()
    
    -- Полоска загрузки (заливка)
    local barFill = Instance.new("Frame")
    barFill.Name = "LoadingBarFill"
    barFill.Size = UDim2.new(0, 0, 1, 0) -- Начинается с 0
    barFill.Position = UDim2.new(0, 0, 0, 0)
    barFill.BackgroundColor3 = Color3.fromRGB(255, 50, 150) -- Неоново-розовый
    barFill.BorderSizePixel = 0
    barFill.ZIndex = 202
    barFill.Parent = barBg
    
    local barFillCorner = Instance.new("UICorner")
    barFillCorner.CornerRadius = UDim.new(0, 12)
    barFillCorner.Parent = barFill
    
    -- Текст процентов
    local percentText = Instance.new("TextLabel")
    percentText.Name = "PercentText"
    percentText.Size = UDim2.new(0, 100, 0, 30)
    percentText.Position = UDim2.new(0.5, -50, 0.5, 20)
    percentText.BackgroundTransparency = 1
    percentText.Text = "0%"
    percentText.TextColor3 = Color3.fromRGB(255, 255, 255)
    percentText.Font = Enum.Font.GothamBold
    percentText.TextSize = 20
    percentText.ZIndex = 201
    percentText.TextTransparency = 1
    percentText.Parent = bg
    
    tweenService:Create(percentText, TweenInfo.new(0.5), {TextTransparency = 0}):Play()
    
    -- Анимация загрузки: от 0% до 100% за 7.5 секунд
    local totalSteps = 100
    local stepTime = 7.5 / totalSteps -- 0.075 секунд на шаг
    
    for i = 1, totalSteps do
        local percent = i
        local fillWidth = (320 * percent) / 100
        
        pcall(function()
            barFill.Size = UDim2.new(0, fillWidth, 1, 0)
            percentText.Text = percent .. "%"
            
            -- Меняем цвет заливки от тёмного к яркому
            local r = 255
            local g = math.floor(50 + (percent * 1.5))
            local b = math.floor(150 - (percent * 0.5))
            barFill.BackgroundColor3 = Color3.fromRGB(r, math.min(g, 255), math.max(b, 50))
        end)
        
        task.wait(stepTime)
    end
    
    -- Завершение загрузки
    task.wait(0.3)
    
    -- Анимация исчезновения
    tweenService:Create(bg, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play()
    task.wait(0.5)
    bg:Destroy()
    
    print("[GhostClient] Загрузка завершена!")
end

