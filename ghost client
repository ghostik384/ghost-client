-- ЗАЩИТА
-- ============================================
local protectionConnections = {}
local disableProtectionFunc = nil

local function enableProtection()
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    if not hum then return end

    pcall(function() hum.FallDamage = false end)
    pcall(function() hum.BreakJointsOnDeath = false end)

    local healthConn = RunService.Heartbeat:Connect(function()
        pcall(function()
            if hum and hum.Parent then
                if hum.Health <= 0 then hum.Health = hum.MaxHealth end
                if hum.FallDamage == true then hum.FallDamage = false end
                if hum.BreakJointsOnDeath == true then hum.BreakJointsOnDeath = false end
            end
        end)
    end)

    table.insert(protectionConnections, healthConn)

    return function()
        pcall(function() healthConn:Disconnect() end)
    end
end

-- ============================================
-- ПЕРЕКЛЮЧЕНИЕ ПЛАТФОРМЫ
-- ============================================
local function togglePlatform()
    if platformActive then
        cleanupPlatform()

if disableProtectionFunc then disableProtectionFunc(); disableProtectionFunc = nil end
        for _, c in ipairs(protectionConnections) do pcall(function() c:Disconnect() end) end
        protectionConnections = {}
        return false
    else
        if createPlatform() then
            platformActive    = true
            wasPlatformActive = true
            startPlatformLoop()
            disableProtectionFunc = enableProtection()
            return true
        end
        return false
    end
end

player.CharacterAdded:Connect(function()
    if wasPlatformActive then
        cleanupPlatform()
        task.wait(0.5)
        if createPlatform() then
            platformActive = true
            startPlatformLoop()
            disableProtectionFunc = enableProtection()
        else
            platformActive    = false
            wasPlatformActive = false
        end
    end
end)

