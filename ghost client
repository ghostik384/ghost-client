-- // СИМУЛЯЦИЯ НАЖАТИЯ НА КНОПКУ // --
local function ClickButton(button)
    if not button then return false end
    
    -- Имитируем нажатие
    if button:IsA("TextButton") or button:IsA("ImageButton") then
        button:CaptureMouse()
        button:MouseButton1Click:Fire()
        -- Анимация нажатия
        local originalColor = button.BackgroundColor3
        button.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
        task.wait(0.05)
        button.BackgroundColor3 = originalColor
        return true
    end
    return false
end

-- // ОСНОВНАЯ ФУНКЦИЯ PERFECT KICK // --
local function PerformPerfectKick()
    local kickBtn = FindKickButton()
    if not kickBtn then
        statusLabel.Text = "❌ Кнопка KICK не найдена!"
        return false
    end
    
    local luckyBlock = FindLuckyBlock()
    if not luckyBlock then
        statusLabel.Text = "⚠️ Lucky Block не найден!"
        return false
    end
    
    statusLabel.Text = "🎯 Нажатие на KICK..."
    ClickButton(kickBtn)
    Notify("⚡ Нажал KICK! Жду тайминг...", 1)
    
    -- Ждём тайминг зарядки
    local startTime = tick()
    statusLabel.Text = "⏳ Зарядка удара... " .. string.format("%.1f", timingSettings.chargeTime) .. " сек"
    
    -- Анимация прогресса в нотификации
    for i = 1, math.floor(timingSettings.chargeTime * 10) do
        if not kickEnabled then return false end
        task.wait(0.1)
        local percent = (tick() - startTime) / timingSettings.chargeTime
        if percent >= 1 then break end
    end
    
    statusLabel.Text = "💥 ИДЕАЛЬНЫЙ УДАР!"
    Notify("🔥 PERFECT KICK! Бросок Lucky Block! 🔥", 1.5)
    
    -- Здесь имитируем бросок (удар по блоку)
    local humanoid = player.Character and player.Character:FindFirstChild("Humanoid")
    if humanoid then
        -- Активируем анимацию удара
        game:GetService("VirtualInputManager"):SendKeyEvent(true, Enum.KeyCode.E, false, game)
        task.wait(0.05)
        game:GetService("VirtualInputManager"):SendKeyEvent(false, Enum.KeyCode.E, false, game)
    end
    
    return true
end

-- // АВТОМАТИЧЕСКИЙ ЦИКЛ // --
local kickEnabled = false
local kickLoop = nil

local function StartKickLoop()
    if kickLoop then kickLoop:Disconnect() end
    
    kickLoop = game:GetService("RunService").RenderStepped:Connect(function()
        if kickEnabled then
            PerformPerfectKick()
            task.wait(2) -- Пауза между ударами, чтобы не спамило
        end
    end)
end

local function StopKickLoop()
    if kickLoop then
        kickLoop:Disconnect()
        kickLoop = nil
    end
end

