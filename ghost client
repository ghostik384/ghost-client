local Logger = {history = {}, maxHistory = 150}
function Logger:add(level, message)
    local timestamp = os.date("%H:%M:%S")
    local entry = {time = timestamp, level = level, message = tostring(message)}
    table.insert(self.history, entry)
    if #self.history > self.maxHistory then table.remove(self.history, 1) end
    print("[" .. timestamp .. "] [" .. level .. "] " .. entry.message)
end
function Logger:Info(msg) self:add("INFO", msg) end
function Logger:Warn(msg) self:add("WARN", msg) end
function Logger:Error(msg) self:add("ERROR", msg) end
function Logger:Debug(msg) self:add("DEBUG", msg) end

