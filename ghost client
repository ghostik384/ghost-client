local function detectExecutor()
    local executors = {
        {name = "Synapse", check = function() return syn and syn.protect_gui end},
        {name = "Krnl", check = function() return krnl and krnl.queue_on_teleport end},
        {name = "Delta", check = function() return delta and delta.console end},
        {name = "Hydrogen", check = function() return hydro and hydro.request end},
        {name = "Fluxus", check = function() return fluxus and fluxus.setclipboard end},
        {name = "Solara", check = function() return solara and solara.setfflag end},
        {name = "Electron", check = function() return electron and electron.execute end},
        {name = "Arceus X", check = function() return arceus and arceus.version end},
    }
    
    for _, executor in ipairs(executors) do
        local success = pcall(function()
            if executor.check() then
                diagnosticData.executor = executor.name
                diagnosticData.environment = executor.name
                LogSystem:Info("Эксплойт: " .. executor.name)
                return true
            end
        end)
        if success then break end
    end
end
