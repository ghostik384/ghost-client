-- Глобальная система логов
local LogSystem = {
    history = {},
    maxHistory = 100
}

function LogSystem:add(level, message)
    local timestamp = os.date("%H:%M:%S")
    local entry = {
        time = timestamp,
        level = level,
        message = tostring(message)
    }
    table.insert(self.history, entry)
    if #self.history > self.maxHistory then
        table.remove(self.history, 1)
    end
    print("[" .. timestamp .. "] [" .. level .. "] " .. entry.message)
end

function LogSystem:Info(msg) self:add("INFO", msg) end
function LogSystem:Warning(msg) self:add("WARN", msg) end
function LogSystem:Error(msg) self:add("ERROR", msg) end
function LogSystem:Debug(msg) self:add("DEBUG", msg) end

