-- ОБРАБОТКА РЕСПАВНА
-- ============================================
player.CharacterAdded:Connect(function(char)
    Logger:Info("Character respawned")
    
    if wasPlatformActive and platformActive then
        Logger:Info("Platform was active, recreating...")
        
        -- Очищаем старую платформу
        cleanupPlatform()
        
        -- Ждём загрузки нового персонажа
        task.wait(0.5)
        
        -- Пересоздаём платформу
        local success, methodName = createPlatformWithFallback()
        if success then
            platformActive = true
            startPlatformMovement()
            disableProtectionFunc = enableProtection()
            Logger:Info("Platform recreated after respawn!")
        else
            platformActive = false
            wasPlatformActive = false
            Logger:Error("Failed to recreate platform after respawn")
        end
    end
end)

