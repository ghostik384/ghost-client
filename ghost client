local function toggleESP()
    espActive = not espActive
    if espActive then
        local target = findBestTarget()
        if target then
            createESP(target)
            Logger:Info("ESP enabled on: " .. target.Name)
            return true
        else
            espActive = false
            Logger:Warn("No target for ESP")
            return false
        end
    else
        clearESP()
        Logger:Info("ESP disabled")
        return false
    end
end

