local function Switch(t)
    for n,btn in pairs(tabBtns) do
        btn.BackgroundColor3 = n==t and Color3.fromRGB(80,80,90) or Color3.fromRGB(35,35,40)
    end
    for n,f in pairs(frames) do
        f.Visible = n==t
    end
end

for n,btn in pairs(tabBtns) do
    btn.MouseButton1Click:Connect(function() Switch(n) end)
end

