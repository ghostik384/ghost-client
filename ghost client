-- // ПОИСК КНОПКИ KICK // --
local function FindKickButton()
    for _, guiObj in pairs(player.PlayerGui:GetDescendants()) do
        if guiObj:IsA("TextButton") then
            local text = guiObj.Text or ""
            if text:upper():find("KICK") then
                return guiObj
            end
        end
        if guiObj:IsA("ImageButton") then
            local text = guiObj.Text or ""
            if text:upper():find("KICK") then
                return guiObj
            end
        end
    end
    return nil
end

-- // НАЖАТИЕ НА КНОПКУ // --
local function ClickButton(button)
    if not button then return false end
    pcall(function()
        button:CaptureMouse()
        button:MouseButton1Click:Fire()
    end)
    return true
end

-- // ОСНОВНАЯ ФУНКЦИЯ // --
local kickEnabled = false
local isKicking = false

local function PerformKick()
    if isKicking then return end
    isKicking = true
    
    local kickBtn = FindKickButton()
    if not kickBtn then
        statusLabel.Text = "❌ Кнопка KICK не найдена"
        isKicking = false
        return
    end
    
    statusLabel.Text = "🎯 Нажимаю KICK..."
    ClickButton(kickBtn)
    Notify("⚡ Нажал KICK! Зарядка...", 1)
    
    -- Ждём тайминг
    statusLabel.Text = "⏳ Зарядка " .. chargeTime .. " сек..."
    task.wait(chargeTime)
    
    statusLabel.Text = "💥 PERFECT KICK!"
    Notify("🔥 PERFECT KICK!", 1)
    
    -- Имитация удара
    pcall(function()
        game:GetService("VirtualInputManager"):SendKeyEvent(true, Enum.KeyCode.E, false, game)
        task.wait(0.05)
        game:GetService("VirtualInputManager"):SendKeyEvent(false, Enum.KeyCode.E, false, game)
    end)
    
    statusLabel.Text = "✅ Готов к следующему удару"
    task.wait(1)
    isKicking = false
end

-- // ЦИКЛ // --
local kickLoop = nil

local function StartLoop()
    if kickLoop then kickLoop:Disconnect() end
    kickLoop = game:GetService("RunService").Heartbeat:Connect(function()
        if kickEnabled then
            PerformKick()
            task.wait(2.5)
        end
    end)
end

local function StopLoop()
    if kickLoop then
        kickLoop:Disconnect()
        kickLoop = nil
    end
end

-- // КНОПКА ВКЛ/ВЫКЛ // --
kickButton.MouseButton1Click:Connect(function()
    kickEnabled = not kickEnabled
    
    if kickEnabled then
