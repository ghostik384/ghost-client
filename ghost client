local PlatformAnimator = {}

function PlatformAnimator:AnimateSine(platform, amplitude, cycleTime)
    if not platform or not platform.Parent then return end
    
    local baseY = platform.Position.Y
    local startTime = tick()
    
    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not platform or not platform.Parent then
            if connection then connection:Disconnect() end
            return
        end
        
        local elapsed = tick() - startTime
        local offset = math.sin(elapsed * (2 * math.pi / cycleTime)) * amplitude
        
        pcall(function()
            if platform.Anchored then
                local pos = platform.Position
                platform.Position = Vector3.new(pos.X, baseY + offset, pos.Z)
            end
        end)
    end)
    
    return connection
end

function PlatformAnimator:AnimateStepped(platform, amplitude, cycleTime)
    if not platform or not platform.Parent then return end
    
    local baseY = platform.Position.Y
    local steps = 10
    local stepDuration = cycleTime / (steps * 2)
    
    local connection
    connection = task.spawn(function()
        while platform and platform.Parent do
            for i = 1, steps do
                if not platform or not platform.Parent then break end
                local targetY = baseY + (amplitude * i / steps)
                pcall(function()
                    if platform.Anchored then
                        platform.Position = Vector3.new(platform.Position.X, targetY, platform.Position.Z)
                    end
                end)
                task.wait(stepDuration)
            end
            for i = steps, 1, -1 do
                if not platform or not platform.Parent then break end
                local targetY = baseY + (amplitude * i / steps)
                pcall(function()
                    if platform.Anchored then
                        platform.Position = Vector3.new(platform.Position.X, targetY, platform.Position.Z)
                    end
                end)
                task.wait(stepDuration)
            end
        end
    end)
    
    return connection
end

function PlatformAnimator:AnimateStatic(platform)
    -- Ничего не делаем, платформа стоит на месте
    return nil
end

function PlatformAnimator:GetAnimationStyles()
    return {
        {name = "Sine Wave", func = function(plat) return PlatformAnimator:AnimateSine(plat, 20, 3) end},
        {name = "Stepped", func = function(plat) return PlatformAnimator:AnimateStepped(plat, 20, 3) end},
        {name = "Static", func = function(plat) return PlatformAnimator:AnimateStatic(plat) end},
    }
end

