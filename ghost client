local ProtectionManager = {}

function ProtectionManager:Enable(humanoid)
    if not humanoid then return nil end
    
    Logger:Info("Enabling protection for humanoid", "ProtectionManager")
    
    -- Сохраняем оригинальные значения
    local originalFallDamage = humanoid.FallDamage
    local originalBreakJoints = humanoid.BreakJointsOnDeath
    local originalWalkSpeed = humanoid.WalkSpeed

-- Применяем защиту
    humanoid.FallDamage = false
    humanoid.BreakJointsOnDeath = false
    humanoid.WalkSpeed = math.min(humanoid.WalkSpeed, 32)
    
    -- Создаём соединения
    local connections = {}
    
    connections.healthCheck = RunService.Heartbeat:Connect(function()
        pcall(function()
            if humanoid and humanoid.Parent then
                if humanoid.Health <= 0 then
                    humanoid.Health = humanoid.MaxHealth
                    Logger:Warn("Health reset prevented", "ProtectionManager")
                end
            end
        end)
    end)
    
    connections.speedCheck = RunService.Heartbeat:Connect(function()
        pcall(function()
            if humanoid and humanoid.Parent then
                if humanoid.WalkSpeed > 32 then
                    humanoid.WalkSpeed = 32
                end
            end
        end)
    end)
    
    connections.fallDamageCheck = RunService.Heartbeat:Connect(function()
        pcall(function()
            if humanoid and humanoid.Parent then
                if humanoid.FallDamage == true then
                    humanoid.FallDamage = false
                end
            end
        end)
    end)
    
    -- Функция отключения
    local function disable()
        Logger:Info("Disabling protection", "ProtectionManager")
        for name, conn in pairs(connections) do
            pcall(function() conn:Disconnect() end)
        end
        pcall(function()
            if humanoid and humanoid.Parent then
                humanoid.FallDamage = originalFallDamage
                humanoid.BreakJointsOnDeath = originalBreakJoints
                humanoid.WalkSpeed = originalWalkSpeed
            end
        end)
    end
    
    return disable
end

