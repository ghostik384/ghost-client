    tabBtns[name] = btn
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1,-20,1,-20)
    f.Position = UDim2.new(0,10,0,10)
    f.BackgroundTransparency = 1
    f.Visible = i==1
    f.Parent = area
    frames[name] = f
